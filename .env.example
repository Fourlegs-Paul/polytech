# 텔레그램 봇 토큰 (필수) — @BotFather → /mybots → dallimi_bot → API Token
BOT_TOKEN=여기에_실제_토큰_붙여넣기

# --- 답변 생성 LLM 설정 (아래 중 하나) ---

# [A] Ollama (추천, 이메일 가입 불필요, 로컬 실행)
#   1) https://ollama.com 설치
#   2) 터미널: ollama pull llama3
#   3) 아래 LLM_PROVIDER=ollama 유지 (또는 비워두면 자동감지)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# [B] OpenAI 호환 API 키가 이미 있는 경우 (이메일 가입 필요)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# 참고: LLM_PROVIDER 를 비워두면 → Ollama 우선, 키 있으면 OpenAI, 둘 다 없으면 정적 스냅샷 폴백
